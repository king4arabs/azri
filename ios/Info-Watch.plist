<?xml version="1.0" encoding="UTF-8"?>
<!--
  Merge these keys into the AzriWatch target's Info.plist in Xcode.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleDisplayName</key>
  <string>AZRI</string>
  <key>CFBundleDevelopmentRegion</key>
  <string>ar_SA</string>
  <key>CFBundleLocalizations</key>
  <array>
    <string>ar</string>
    <string>en</string>
  </array>

  <key>NSHealthShareUsageDescription</key>
  <string>AZRI تقرأ مؤشرات صحية عامة (النبض، تذبذب النبض، تشبع الأوكسجين) لدعم المتابعة على الساعة. / AZRI reads general health signals (heart rate, HRV, blood-oxygen) on the Apple Watch to support passive monitoring.</string>

  <key>WKBackgroundModes</key>
  <array>
    <string>workout-processing</string>
  </array>
</dict>
</plist>
