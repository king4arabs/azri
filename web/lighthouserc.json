{
  "ci": {
    "collect": {
      "startServerCommand": "npm run start --workspace=web -- --port=3100 --hostname=127.0.0.1",
      "startServerReadyPattern": "Ready in",
      "startServerReadyTimeout": 60000,
      "url": [
        "http://127.0.0.1:3100/",
        "http://127.0.0.1:3100/about",
        "http://127.0.0.1:3100/solutions",
        "http://127.0.0.1:3100/patients-families",
        "http://127.0.0.1:3100/doctors",
        "http://127.0.0.1:3100/institutions",
        "http://127.0.0.1:3100/technology",
        "http://127.0.0.1:3100/pricing",
        "http://127.0.0.1:3100/faq",
        "http://127.0.0.1:3100/contact",
        "http://127.0.0.1:3100/legal/privacy",
        "http://127.0.0.1:3100/legal/terms",
        "http://127.0.0.1:3100/legal/medical-disclaimer"
      ],
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop",
        "chromeFlags": "--no-sandbox --headless=new --disable-gpu --disable-dev-shm-usage"
      }
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }],
        "categories:seo": ["warn", { "minScore": 0.9 }],
        "categories:performance": ["warn", { "minScore": 0.8 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
