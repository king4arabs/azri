# -----------------------------------------------------------------------------
# @azri/web — environment variables
#
# Policy reminder (SECURITY.md#env-example-policy):
#   - No real values. Use placeholders or leave blank.
#   - Every variable that production reads must be listed here.
#   - Variables prefixed NEXT_PUBLIC_ are exposed to the browser - never
#     put secrets behind that prefix.
# -----------------------------------------------------------------------------

# -------- Runtime --------
# Port the Next.js server listens on. Defaults to 3000 if unset.
PORT=3000

# -------- Public config (exposed to the browser) --------
# Base URL of the @azri/api. Used by future client code; no network calls yet.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
