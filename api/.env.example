# AZRI API — env example. No real values. Every key documented.
# See SECURITY.md "env-example policy" for the rules.

# --- HTTP -----------------------------------------------------------
# Public bind host inside the container. Defaults to 0.0.0.0.
HOST=0.0.0.0
# Port the API listens on. Defaults to 8080.
PORT=8080
# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
# Comma-separated list of allowed origins for CORS (no wildcards in prod).
ALLOWED_ORIGINS=http://localhost:3000

# --- Auth (placeholder until ADR-0004) ------------------------------
# JWT issuer URL — Clerk / Auth0 / SuperTokens. Verified via JWKS.
AUTH_ISSUER_URL=
# Expected audience claim.
AUTH_AUDIENCE=azri-api

# --- Whoop webhook --------------------------------------------------
# HMAC secret used to verify Whoop webhook signatures. Rotate quarterly.
WHOOP_WEBHOOK_SECRET=
# OAuth client id / secret for the Whoop adapter (server-side only).
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
# Public callback URL registered with Whoop for the OAuth code exchange.
WHOOP_REDIRECT_URI=

# --- Watch ingest ---------------------------------------------------
# Pre-shared key (per device install) for the watch ingest endpoint
# until full mTLS / device attestation is in place. Stored hashed.
WATCH_INGEST_DEV_KEY_HMAC_PEPPER=

# --- Storage --------------------------------------------------------
# Postgres connection string with row-level security policies enabled.
DATABASE_URL=
# Redis for rate-limit + idempotency cache.
REDIS_URL=
