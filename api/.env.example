# -----------------------------------------------------------------------------
# @azri/api — environment variables
#
# Policy reminder (SECURITY.md#env-example-policy):
#   - No real values. Use placeholders or leave blank.
#   - Every variable is documented here. If production reads a variable that
#     is not listed here, that is a bug.
#   - PHI-adjacent variables are annotated "# PHI" for reviewer visibility.
# -----------------------------------------------------------------------------

# -------- Runtime --------
# One of: development | test | staging | production
NODE_ENV=development
# Bind address for the HTTP server. Use 127.0.0.1 for local, 0.0.0.0 for containers.
HOST=0.0.0.0
# HTTP port to listen on.
PORT=3001
# pino log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=debug

# -------- OpenAPI --------
# If "true" (or "1"), expose the Swagger UI at /docs. Default: off in production.
EXPOSE_OPENAPI_UI=true

# -------- CORS --------
# Comma-separated origins allowed to call the API.
CORS_ORIGINS=http://localhost:3000

# -------- Rate limiting --------
# Max requests per window per IP (global; per-route limits override later).
RATE_LIMIT_MAX=200
# Window in milliseconds.
RATE_LIMIT_WINDOW_MS=60000

# -------- Build metadata (optional, injected by CI) --------
# Short git SHA returned by /version. Leave empty locally.
GIT_SHA=
