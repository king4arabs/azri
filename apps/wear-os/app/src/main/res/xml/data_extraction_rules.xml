<?xml version="1.0" encoding="utf-8"?>
<!-- AZRI does not allow OEM cloud backups of app data — health data must
     stay in our controlled storage path. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="device" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
    </device-transfer>
</data-extraction-rules>
